[Unit]
Description=YANKA FastAPI Backend
After=network.target

[Service]
User=ssm-user
WorkingDirectory=/home/ssm-user/YANKA-AI-Edu-Assistant/yanka/Webapp/backend
ExecStart=/home/ssm-user/YANKA-AI-Edu-Assistant/yanka/Webapp/backend/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
EnvironmentFile=/home/ssm-user/YANKA-AI-Edu-Assistant/yanka/Webapp/backend/.env

[Install]
WantedBy=multi-user.target
